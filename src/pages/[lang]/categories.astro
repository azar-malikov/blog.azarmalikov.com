---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';
import { listBlogForLocale } from '@/lib/content/blog';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
const posts = listBlogForLocale(lang);
const map = new Map<string, typeof posts>();
for (const p of posts) {
  for (const c of p.meta.category) {
    if (!map.has(c)) map.set(c, []);
    map.get(c)!.push(p);
  }
}
const cats = [...map.keys()].sort();
---

<BaseLayout title={t(lang, 'categories.title')} description="Browse by category." lang={lang} path={path}>
  <header class="mb-12 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Topics</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'categories.title')}</h1>
  </header>

  <div class="space-y-10">
    {
      cats.map((c) => (
        <section>
          <h2 class="font-display text-3xl text-ink">{c}</h2>
          <div class="mt-4 space-y-3">
            {map.get(c)!.map((p) => (
              <a class="block text-ink hover:text-signal" href={`/${lang}/blog/${p.slug}/`}>
                {p.fm.title}
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
