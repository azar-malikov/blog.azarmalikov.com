---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';
import { listBlogForLocale } from '@/lib/content/blog';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
const posts = listBlogForLocale(lang);
const map = new Map<string, typeof posts>();
for (const p of posts) {
  for (const tag of p.meta.tags) {
    if (!map.has(tag)) map.set(tag, []);
    map.get(tag)!.push(p);
  }
}
const tags = [...map.keys()].sort((a, b) => a.localeCompare(b));
---

<BaseLayout title={t(lang, 'tags.title')} description="Browse by tags." lang={lang} path={path}>
  <header class="mb-12 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Tags</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'tags.title')}</h1>
  </header>

  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full border border-line/70 bg-canvas-elevated px-3 py-1 text-sm text-ink-muted">
        {tag} · {map.get(tag)!.length}
      </span>
    ))}
  </div>

  <div class="mt-12 space-y-10">
    {
      tags.map((tag, idx) => (
        <section id={`tag-${idx}`}>
          <h2 class="font-display text-2xl text-ink">{tag}</h2>
          <div class="mt-4 space-y-3">
            {map.get(tag)!.map((p) => (
              <a class="block text-ink hover:text-signal" href={`/${lang}/blog/${p.slug}/`}>
                {p.fm.title}
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
