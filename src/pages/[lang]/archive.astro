---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';
import { listBlogForLocale } from '@/lib/content/blog';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
const posts = listBlogForLocale(lang);
const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = new Date(p.fm.publishedAt).getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<BaseLayout title={t(lang, 'nav.archive')} description="Archive by year." lang={lang} path={path}>
  <header class="mb-12 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Archive</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'nav.archive')}</h1>
    <p class="mt-4 text-lg text-ink-muted">{t(lang, 'archive.byYear')}</p>
  </header>

  <div class="space-y-12">
    {
      years.map((y) => (
        <section>
          <h2 class="font-display text-3xl text-ink">{y}</h2>
          <div class="mt-6 space-y-4">
            {byYear.get(y)!.map((p) => (
              <a
                href={`/${lang}/blog/${p.slug}/`}
                class="block rounded-2xl border border-line/60 bg-canvas-elevated/80 p-5 transition hover:border-accent/40"
              >
                <p class="text-sm text-ink-faint">{p.fm.publishedAt}</p>
                <p class="mt-2 font-display text-xl text-ink">{p.fm.title}</p>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
