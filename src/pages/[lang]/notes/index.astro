---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';
import { listNotesForLocale } from '@/lib/content/notes';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
const items = listNotesForLocale(lang);
---

<BaseLayout title={t(lang, 'nav.notes')} description="Personal fragments, reminders, and seeds." lang={lang} path={path}>
  <header class="mb-12 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Notes</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'nav.notes')}</h1>
    <p class="mt-4 text-lg text-ink-muted">
      A polished journal layer—future-ready for private drafts and authenticated notes behind an edge access layer.
    </p>
  </header>

  <div class="space-y-4">
    {
      items.map((n) => (
        <a
          href={`/${lang}/notes/${n.id}/`}
          class="block rounded-2xl border border-line/60 bg-canvas-elevated/80 p-5 transition hover:border-accent/40"
        >
          <div class="flex items-center justify-between gap-3">
            <p class="font-display text-xl text-ink">{n.meta.title}</p>
            <span class="rounded-full border border-line/60 px-2 py-0.5 text-[11px] text-ink-faint">
              {n.meta.mood ?? 'note'}
            </span>
          </div>
          <p class="mt-2 text-sm text-ink-muted">Visibility: {n.meta.visibility}</p>
        </a>
      ))
    }
  </div>

  {items.length === 0 ? (
    <p class="rounded-2xl border border-dashed border-line/60 bg-canvas-muted/30 p-8 text-sm text-ink-muted">
      No notes for this locale yet.
    </p>
  ) : null}
</BaseLayout>
