---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
---

<BaseLayout title={t(lang, 'nav.about')} description="About Azar Malikov." lang={lang} path={path}>
  <header class="mb-10 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">About</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'nav.about')}</h1>
  </header>

  <div class="grid gap-10 lg:grid-cols-[220px_1fr]">
    <div class="rounded-3xl border border-line/60 bg-canvas-muted/40 p-6">
      <div class="aspect-square w-full rounded-2xl border border-dashed border-line/60 bg-canvas-elevated/60"></div>
      <p class="mt-4 text-xs text-ink-faint">Profile image placeholder</p>
    </div>
    <div class="prose-article max-w-measure">
      <p>
        I build and study systems where risk becomes actionable: threat modeling, detection engineering, and disciplined
        offensive practice in authorized environments.
      </p>
      <h2>Focus</h2>
      <ul>
        <li>Offensive security craft with editorial clarity</li>
        <li>Identity and telemetry design for real-world SOC constraints</li>
        <li>Teaching through structure: writeups → reusable operator knowledge</li>
      </ul>
      <h2>Values</h2>
      <p>
        Calm language, explicit ethics, reproducible evidence. Security work should get more boring as it gets more serious—because boring is where teams can collaborate safely.
      </p>
      <h2>Journey (abridged)</h2>
      <ul>
        <li>Years of hands-on labs, assessments, and research notes</li>
        <li>Continuous translation between attacker tradecraft and defender reality</li>
        <li>This site: a single publishing system for long-form writing and operational knowledge</li>
      </ul>
    </div>
  </div>
</BaseLayout>
