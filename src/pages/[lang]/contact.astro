---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
---

<BaseLayout title={t(lang, 'nav.contact')} description="Contact channels." lang={lang} path={path}>
  <header class="mb-10 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Contact</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'nav.contact')}</h1>
    <p class="mt-4 text-lg text-ink-muted">{t(lang, 'contact.formNote')}</p>
  </header>

  <div class="grid gap-6 md:grid-cols-2">
    <div class="rounded-2xl border border-line/60 bg-canvas-elevated/80 p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Email</p>
      <p class="mt-3 text-lg text-ink">hello@azarmalikov.com</p>
      <p class="mt-2 text-sm text-ink-muted">Replace with your preferred public address.</p>
    </div>
    <div class="rounded-2xl border border-line/60 bg-canvas-elevated/80 p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Social</p>
      <p class="mt-3 text-sm text-ink-muted">Add LinkedIn / GitHub / X links here as needed.</p>
    </div>
  </div>

  <form class="mt-10 space-y-4 rounded-2xl border border-dashed border-line/60 bg-canvas-muted/30 p-6">
    <p class="text-sm font-semibold text-ink">Message (placeholder)</p>
    <label class="block text-sm text-ink-muted">
      Name
      <input class="mt-2 w-full rounded-xl border border-line/70 bg-canvas-elevated px-3 py-2 text-sm" disabled />
    </label>
    <label class="block text-sm text-ink-muted">
      Email
      <input class="mt-2 w-full rounded-xl border border-line/70 bg-canvas-elevated px-3 py-2 text-sm" disabled />
    </label>
    <label class="block text-sm text-ink-muted">
      Message
      <textarea class="mt-2 w-full rounded-xl border border-line/70 bg-canvas-elevated px-3 py-2 text-sm" rows={5} disabled
      ></textarea>
    </label>
    <button type="submit" class="rounded-full bg-accent px-5 py-2 text-sm font-semibold text-canvas opacity-60" disabled
      >Send</button
    >
  </form>
</BaseLayout>
