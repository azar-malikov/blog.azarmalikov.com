---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';
import { listCheatsForLocale } from '@/lib/content/cheatsheets';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
const items = listCheatsForLocale(lang);
const groups = new Map<string, typeof items>();
for (const it of items) {
  const k = it.meta.category;
  if (!groups.has(k)) groups.set(k, []);
  groups.get(k)!.push(it);
}
---

<BaseLayout title={t(lang, 'nav.cheatsheets')} description="Operational snippets and reusable commands." lang={lang} path={path}>
  <header class="mb-12 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Cheat sheets</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'nav.cheatsheets')}</h1>
    <p class="mt-4 text-lg text-ink-muted">Compact, copy-friendly blocks promoted from labs and repeated practice.</p>
  </header>

  <div class="space-y-12">
    {
      [...groups.entries()].map(([cat, rows]) => (
        <section>
          <h2 class="font-display text-2xl text-ink">{cat}</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {rows.map((c) => (
              <a
                href={`/${lang}/cheatsheets/${c.id}/`}
                class="rounded-2xl border border-line/60 bg-canvas-elevated/80 p-5 transition hover:border-accent/40"
              >
                <p class="text-xs text-ink-faint">{c.meta.sourceTool ?? 'Notes'}</p>
                <p class="mt-2 font-display text-xl text-ink">{c.meta.title}</p>
                <p class="mt-2 text-sm text-ink-muted">{c.meta.shortDescription}</p>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>

  {items.length === 0 ? (
    <p class="rounded-2xl border border-dashed border-line/60 bg-canvas-muted/30 p-8 text-sm text-ink-muted">
      No cheat sheets for this locale yet.
    </p>
  ) : null}
</BaseLayout>
