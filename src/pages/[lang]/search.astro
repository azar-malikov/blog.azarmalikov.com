---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
---

<BaseLayout title={t(lang, 'nav.search')} description="Search across all content types." lang={lang} path={path}>
  <header class="mb-10 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Search</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'nav.search')}</h1>
    <p class="mt-4 text-lg text-ink-muted">
      Keyboard-first search powered by a static index generated at build time. Pagefind also indexes the built HTML for deep matches.
    </p>
  </header>

  <div class="rounded-2xl border border-line/60 bg-canvas-muted/40 p-5">
    <label class="sr-only" for="q">Query</label>
    <input
      id="q"
      type="search"
      class="w-full rounded-xl border border-line/70 bg-canvas-elevated px-4 py-3 text-sm text-ink outline-none ring-accent/30 focus:ring-2"
      placeholder={t(lang, 'search.placeholder')}
      autocomplete="off"
    />
    <div class="mt-4 flex flex-wrap gap-2 text-xs text-ink-muted">
      <span>{t(lang, 'search.scopeAll')}</span>
    </div>
  </div>

  <div id="search-results" class="mt-8 space-y-3"></div>

  <p class="mt-8 text-xs text-ink-faint">
    Tip: press <kbd class="rounded border border-line/60 bg-canvas-elevated px-1">/</kbd> to focus search (when implemented sitewide).
  </p>
</BaseLayout>

<script is:inline>
  const input = document.getElementById('q');
  const out = document.getElementById('search-results');
  let searchData = [];

  async function load() {
    const res = await fetch('/search-index.json');
    searchData = await res.json();
  }

  function score(item, q) {
    const hay = (item.title + ' ' + item.excerpt + ' ' + (item.tags || []).join(' ')).toLowerCase();
    return hay.includes(q) ? 1 : 0;
  }

  function render(q) {
    if (!out) return;
    const query = q.trim().toLowerCase();
    if (!query) {
      out.innerHTML = '';
      return;
    }
    const hits = searchData
      .filter((item) => score(item, query) > 0)
      .slice(0, 30);
    out.innerHTML = hits
      .map(
        (item) => `
        <a class="block rounded-2xl border border-line/60 bg-canvas-elevated/80 p-4 transition hover:border-accent/40" href="${item.href}">
          <div class="text-xs text-ink-faint">${item.kind} · ${item.locale}</div>
          <div class="mt-2 font-display text-lg text-ink">${item.title}</div>
          <div class="mt-2 text-sm text-ink-muted">${item.excerpt || ''}</div>
        </a>`
      )
      .join('');
  }

  load().catch(() => {});
  input?.addEventListener('input', (e) => render(e.target.value));
</script>
