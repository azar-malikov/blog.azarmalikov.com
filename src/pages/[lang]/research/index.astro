---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { langStaticPaths } from '@/lib/i18n/routing';
import { listResearchForLocale } from '@/lib/content/research';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
const items = listResearchForLocale(lang);
---

<BaseLayout title={t(lang, 'nav.research')} description="Research threads and future projects." lang={lang} path={path}>
  <header class="mb-12 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Research</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, 'nav.research')}</h1>
    <p class="mt-4 text-lg text-ink-muted">Ideas with status: from seed to shipped—linked back to writing and labs.</p>
  </header>

  <div class="space-y-4">
    {
      items.map((r) => (
        <a
          href={`/${lang}/research/${r.slug}/`}
          class="block rounded-2xl border border-line/60 bg-canvas-elevated/80 p-6 transition hover:border-accent/40"
        >
          <div class="flex flex-wrap items-center gap-3 text-xs text-ink-faint">
            <span>{r.meta.status}</span>
          </div>
          <h2 class="mt-3 font-display text-2xl text-ink">{r.meta.title}</h2>
        </a>
      ))
    }
  </div>

  {items.length === 0 ? (
    <p class="rounded-2xl border border-dashed border-line/60 bg-canvas-muted/30 p-8 text-sm text-ink-muted">
      No research notes for this locale yet.
    </p>
  ) : null}
</BaseLayout>
