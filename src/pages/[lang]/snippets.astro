---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isLocale, type Locale } from '@/lib/constants';
import { langStaticPaths } from '@/lib/i18n/routing';
import { getAllSnippets } from '@/lib/content/snippets';

export function getStaticPaths() {
  return langStaticPaths();
}

const { lang: raw } = Astro.params;
if (!isLocale(raw ?? '')) throw new Error('Invalid locale');
const lang = raw as Locale;
const path = Astro.url.pathname;
const snippets = getAllSnippets();
---

<BaseLayout title="Reusable snippets" description="Shared operational snippets with lineage." lang={lang} path={path}>
  <header class="mb-10 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Engine</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">Reusable snippets</h1>
    <p class="mt-4 text-lg text-ink-muted">
      Centralized IDs for commands promoted from writeups into cheat sheets—back-linked via <code class="font-mono text-sm">usedIn</code>.
    </p>
  </header>

  <div class="space-y-6">
    {
      snippets.map((s) => (
        <section class="rounded-2xl border border-line/60 bg-canvas-elevated/80 p-6">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <h2 class="font-display text-2xl text-ink">{s.title}</h2>
            <span class="rounded-full border border-line/60 px-2 py-0.5 text-[11px] text-ink-faint">{s.id}</span>
          </div>
          <pre class="mt-4 overflow-x-auto rounded-xl border border-line/60 bg-[#0f1218] p-4 font-mono text-[13px] text-[#e8e4dc]"><code>{s.body}</code></pre>
          <p class="mt-3 text-xs text-ink-faint">Tags: {s.tags?.join(', ') ?? '—'}</p>
        </section>
      ))
    }
  </div>
</BaseLayout>
