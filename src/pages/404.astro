---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { localizedPath } from '@/lib/paths';
import { t } from '@/lib/i18n/ui';

const lang = 'en';
---

<BaseLayout title={t(lang, '404.title')} description={t(lang, '404.body')} lang={lang} path="/404" noindex>
  <div class="max-w-2xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">404</p>
    <h1 class="mt-3 font-display text-display-xl text-ink">{t(lang, '404.title')}</h1>
    <p class="mt-4 text-lg text-ink-muted">{t(lang, '404.body')}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a class="rounded-full bg-accent px-5 py-2 text-sm font-semibold text-canvas" href={localizedPath(lang, '/search')}
        >Search</a
      >
      <a
        class="rounded-full border border-line/70 bg-canvas-elevated px-5 py-2 text-sm font-semibold text-ink"
        href={localizedPath(lang, '/archive')}>Archive</a
      >
    </div>
  </div>
</BaseLayout>
