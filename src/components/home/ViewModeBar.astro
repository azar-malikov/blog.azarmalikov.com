---
import type { Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section
  class="my-14 border border-line/50 bg-canvas-muted/25 px-5 py-6 md:px-10 md:py-8"
  aria-labelledby="viewmodes-label"
>
  <div class="mx-auto flex max-w-content flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
    <div class="max-w-md">
      <p id="viewmodes-label" class="studio-kicker text-signal/90">{t(lang, 'studio.viewModes')}</p>
      <p class="mt-3 font-body text-sm leading-relaxed text-ink-muted">
        <strong class="font-semibold text-ink">{t(lang, 'modes.reader')}</strong> —
        narrow measure, serif body. <strong class="font-semibold text-ink">{t(lang, 'modes.operator')}</strong> —
        wide canvas for tables and side-by-side. <strong class="font-semibold text-ink">{t(lang, 'modes.study')}</strong>
        — tighter rhythm for recall. Stored in <code class="font-mono text-[11px] text-ink-muted">localStorage</code>; future
        sync could map to your account.
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <button
        type="button"
        class="view-mode-btn border border-line/60 bg-canvas-elevated px-3 py-2 font-mono text-[11px] font-medium uppercase tracking-wider text-ink-muted transition hover:border-signal/50 hover:text-ink"
        data-mode="reader"
      >
        {t(lang, 'modes.reader')}
      </button>
      <button
        type="button"
        class="view-mode-btn border border-line/60 bg-canvas-elevated px-3 py-2 font-mono text-[11px] font-medium uppercase tracking-wider text-ink-muted transition hover:border-signal/50 hover:text-ink"
        data-mode="operator"
      >
        {t(lang, 'modes.operator')}
      </button>
      <button
        type="button"
        class="view-mode-btn border border-line/60 bg-canvas-elevated px-3 py-2 font-mono text-[11px] font-medium uppercase tracking-wider text-ink-muted transition hover:border-signal/50 hover:text-ink"
        data-mode="study"
      >
        {t(lang, 'modes.study')}
      </button>
      <button
        type="button"
        class="border border-dashed border-line/70 bg-transparent px-3 py-2 font-mono text-[11px] font-medium uppercase tracking-wider text-ink-faint transition hover:border-line hover:text-ink"
        id="density-toggle"
      >
        {t(lang, 'modes.density')}
      </button>
    </div>
  </div>
</section>

<script is:inline>
  const root = document.documentElement;
  document.querySelectorAll('.view-mode-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = btn.getAttribute('data-mode');
      if (!mode) return;
      root.setAttribute('data-view-mode', mode);
      localStorage.setItem('viewMode', mode);
    });
  });
  document.getElementById('density-toggle')?.addEventListener('click', () => {
    const next = root.getAttribute('data-density') === 'compact' ? 'comfortable' : 'compact';
    root.setAttribute('data-density', next);
    localStorage.setItem('density', next);
  });
</script>
