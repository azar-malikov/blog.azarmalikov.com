---
import type { Locale } from '@/lib/constants';
import { SITE } from '@/lib/constants';
import { localizedPath } from '@/lib/paths';
import { t } from '@/lib/i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<footer class="relative z-10 border-t border-line/60 bg-canvas-muted/30">
  <div class="studio-rule mx-auto max-w-content opacity-80"></div>
  <div class="mx-auto max-w-content px-5 py-16 md:px-10 md:py-20">
    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <p class="studio-kicker">{SITE.studioCode}</p>
        <p class="mt-4 font-display text-3xl text-ink md:text-4xl">{SITE.name}</p>
        <p class="mt-6 max-w-md font-body text-base leading-relaxed text-ink-muted">{t(lang, 'footer.signature')}</p>
        <p class="mt-10 font-mono text-xs text-ink-faint">© {new Date().getFullYear()} · {t(lang, 'footer.rights')}</p>
      </div>
      <div class="grid grid-cols-2 gap-10 sm:grid-cols-3 lg:grid-cols-2">
        <div>
          <p class="studio-kicker mb-4">{t(lang, 'home.masthead.index')}</p>
          <ul class="space-y-2 font-ui text-sm text-ink-muted">
            <li><a class="transition hover:text-ink" href={localizedPath(lang, '/archive')}>{t(lang, 'nav.archive')}</a></li>
            <li><a class="transition hover:text-ink" href={localizedPath(lang, '/categories')}>{t(lang, 'nav.categories')}</a></li>
            <li><a class="transition hover:text-ink" href={localizedPath(lang, '/tags')}>{t(lang, 'nav.tags')}</a></li>
            <li><a class="transition hover:text-ink" href={localizedPath(lang, '/snippets')}>{t(lang, 'studio.snippets')}</a></li>
          </ul>
        </div>
        <div>
          <p class="studio-kicker mb-4">{t(lang, 'nav.privacy')}</p>
          <ul class="space-y-2 font-ui text-sm text-ink-muted">
            <li><a class="transition hover:text-ink" href={localizedPath(lang, '/privacy')}>{t(lang, 'nav.privacy')}</a></li>
            <li><a class="transition hover:text-ink" href={localizedPath(lang, '/terms')}>{t(lang, 'nav.terms')}</a></li>
            <li><a class="transition hover:text-ink" href={localizedPath(lang, '/rss.xml')}>RSS</a></li>
          </ul>
        </div>
      </div>
    </div>
    <p class="mt-14 max-w-2xl border-t border-line/40 pt-8 font-body text-xs leading-relaxed text-ink-faint">
      Interconnected content is declared in each folder’s <code class="font-mono text-[11px] text-ink-muted">meta.json</code>—ready for graph APIs, translation pipelines, or private layers without route churn.
    </p>
  </div>
</footer>
