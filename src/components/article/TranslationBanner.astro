---
import type { Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
interface Props {
  lang: Locale;
  stale?: boolean;
  alternates: Partial<Record<Locale, string>>;
}

const { lang, stale, alternates } = Astro.props;
const keys = Object.keys(alternates).filter((k) => k !== lang) as Locale[];
---

{(stale || keys.length > 0) && (
  <div class="mb-8 space-y-3 rounded-2xl border border-line/60 bg-canvas-muted/50 p-5 text-sm text-ink-muted">
    {stale ? (
      <p>
        <span class="font-semibold text-warn">{t(lang, 'common.translation')}:</span>{' '}
        {t(lang, 'common.staleTranslation')}
      </p>
    ) : null}
    {keys.length > 0 ? (
      <div class="flex flex-wrap gap-2">
        {keys.map((k) => (
          <a
            class="rounded-full border border-line/70 bg-canvas-elevated px-3 py-1 text-xs font-semibold text-ink hover:border-accent/40"
            href={alternates[k]}
          >
            {k.toUpperCase()}
          </a>
        ))}
      </div>
    ) : null}
  </div>
)}
