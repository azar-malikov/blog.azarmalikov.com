---
import type { Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';
import { absoluteUrl } from '@/lib/seo';

interface Props {
  lang: Locale;
  urlPath: string;
  title: string;
}

const { lang, urlPath, title } = Astro.props;
const shareUrl = absoluteUrl(urlPath);
---

<div class="mt-10 flex flex-wrap items-center gap-3 border-t border-line/60 pt-8 text-sm text-ink-muted">
  <span class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-faint">Share</span>
  <a
    class="rounded-full border border-line/70 bg-canvas-elevated px-3 py-1 text-xs font-semibold hover:border-accent/40"
    href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(shareUrl)}`}
    target="_blank"
    rel="noreferrer"
  >
    X / Twitter
  </a>
  <a
    class="rounded-full border border-line/70 bg-canvas-elevated px-3 py-1 text-xs font-semibold hover:border-accent/40"
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
    target="_blank"
    rel="noreferrer"
  >
    LinkedIn
  </a>
  <button
    type="button"
    class="copy-link rounded-full border border-line/70 bg-canvas-elevated px-3 py-1 text-xs font-semibold hover:border-accent/40"
    data-url={shareUrl}
  >
    {t(lang, 'common.copy')} link
  </button>
</div>

<script is:inline>
  document.querySelectorAll('.copy-link').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url');
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        btn.textContent = 'Copied';
        setTimeout(() => (btn.textContent = 'Copy link'), 1400);
      } catch {}
    });
  });
</script>
