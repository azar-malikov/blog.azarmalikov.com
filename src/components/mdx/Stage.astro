---
interface Props {
  id: string;
  title: string;
  summary?: string;
}

const { id, title, summary } = Astro.props;
---

<section
  id={id}
  data-stage
  class="stage-block mb-14 scroll-mt-32 border border-line/50 bg-canvas-muted/20 p-6 md:p-9"
>
  <header class="mb-6 border-b border-line/40 pb-5">
    <p class="font-mono text-[10px] font-medium uppercase tracking-[0.28em] text-ink-faint">Stage</p>
    <h2 class="mt-2 font-display text-2xl text-ink md:text-3xl">{title}</h2>
    {summary ? <p class="mt-3 max-w-2xl text-sm leading-relaxed text-ink-muted">{summary}</p> : null}
  </header>
  <div class="prose-article">
    <slot />
  </div>
</section>
