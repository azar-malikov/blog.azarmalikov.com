---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="not-prose my-6 overflow-hidden rounded-xl border border-line/60 bg-[#0f1218] text-[#e8e4dc] shadow-inner">
  {title ? (
    <div class="border-b border-white/10 px-4 py-2 text-xs font-medium uppercase tracking-[0.16em] text-white/50">
      {title}
    </div>
  ) : null}
  <pre class="overflow-x-auto p-4 font-mono text-[13px] leading-relaxed"><slot /></pre>
</div>
