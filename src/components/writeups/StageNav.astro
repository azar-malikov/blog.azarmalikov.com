---
import type { Locale } from '@/lib/constants';
import { t } from '@/lib/i18n/ui';

interface Props {
  lang: Locale;
  stageOrder: string[];
  labels: Record<string, string>;
}

const { stageOrder, labels, lang } = Astro.props;
---

<aside class="hidden lg:block">
  <div class="sticky top-32 max-h-[70vh] overflow-auto rounded-2xl border border-line/60 bg-canvas-muted/40 p-5">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-faint">{t(lang, 'writeups.stages')}</p>
    <ol class="mt-4 space-y-2 text-sm">
      {stageOrder.map((id) => (
        <li>
          <a class="text-ink-muted hover:text-ink" href={`#${id}`}>
            {labels[id] ?? id}
          </a>
        </li>
      ))}
    </ol>
  </div>
</aside>
